# Voice / AI master switch. Keep false to use the remote WITHOUT any AI/cloud setup.
# Voice runs through the cloud ai-proxy: NO AI keys live on this device — you only
# need a valid LICENSE_TOKEN below.
ENABLE_VOICE=false

# --- Voice AI proxy ---
# Optional override (default shown):
# AI_PROXY_URL=https://tbijfdbtauzxbsbkujbs.functions.supabase.co/ai-proxy

# Access control: shared pairing token used when Supabase is OFF.
PAIRING_TOKEN=

# --- Commercialization / licensing ---
LICENSE_API_URL=https://tbijfdbtauzxbsbkujbs.functions.supabase.co/validate-license
LICENSE_TOKEN=
GITHUB_REPO=Gusitir/LinuxRemotePlayer
# NOTE: Stripe link in TEST mode — switch to the live link before selling.
BUY_URL=https://buy.stripe.com/test_5kQ3cv99t9aY8pu1aVe3e00

# Keyboard layout for the UInput emulator. Valid: us | es | latam (default: us)
# Note for es/latam: < and > require KEY_102ND. Brackets/braces via AltGr not covered.
KEYBOARD_LAYOUT=us
