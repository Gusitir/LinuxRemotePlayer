# Voice / AI master switch. Keep false to use the remote WITHOUT any AI/cloud setup.
# Set true ONLY after configuring the cloud STT/LLM keys below.
ENABLE_VOICE=false

# --- Cloud AI (voice intent engine) ---
# Production stack (validated 2026-07-19): Together AI — Whisper-large-v3 (STT) +
# Qwen2.5-7B-Instruct-Turbo (intent). URLs/models default to this stack; you only
# need the two keys. Any OpenAI-compatible provider works by overriding the URLs.
CLOUD_STT_KEY=
CLOUD_LLM_KEY=
# Optional overrides (defaults shown):
# CLOUD_STT_URL=https://api.together.xyz/v1/audio/transcriptions
# CLOUD_STT_MODEL=openai/whisper-large-v3
# CLOUD_LLM_URL=https://api.together.xyz/v1/chat/completions
# CLOUD_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# Access control: shared pairing token used when Supabase is OFF.
PAIRING_TOKEN=

# --- Commercialization / licensing ---
LICENSE_API_URL=https://tbijfdbtauzxbsbkujbs.functions.supabase.co/validate-license
LICENSE_TOKEN=
GITHUB_REPO=Gusitir/LinuxRemotePlayer
# NOTE: Stripe link in TEST mode — switch to the live link before selling.
BUY_URL=https://buy.stripe.com/test_5kQ3cv99t9aY8pu1aVe3e00

# Keyboard layout for the UInput emulator. Valid: us | es | latam (default: us)
# Note for es/latam: < and > require KEY_102ND. Brackets/braces via AltGr not covered.
KEYBOARD_LAYOUT=us
