# Voice / AI master switch. Keep false to use the remote WITHOUT any AI/cloud setup.
# Set true ONLY after configuring the STT/LLM keys (or local AI) below.
ENABLE_VOICE=false

# Cloud API Keys
# Default: NVIDIA NIM for STT and OpenRouter for LLM.
# You can override URLs to use Together.ai or others:
NVIDIA_NIM_API_KEY=
OPENROUTER_API_KEY=

# --- OVERRIDES PARA TOGETHER.AI (Opcional) ---
# CLOUD_STT_URL=https://api.together.xyz/v1/audio/transcriptions
# CLOUD_STT_KEY=tu_api_key_de_together
# CLOUD_STT_MODEL=nvidia/nemotron-3.5-asr
#
# CLOUD_LLM_URL=https://api.together.xyz/v1/chat/completions
# CLOUD_LLM_KEY=tu_api_key_de_together
# CLOUD_LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# ---------------------------------------------

# Local AI API (Fase 5)
USE_LOCAL_AI=false
LOCAL_WHISPER_URL=http://TU_IP_PC_TRABAJO:8001/v1/audio/transcriptions
LOCAL_OLLAMA_URL=http://TU_IP_PC_TRABAJO:11434/v1/chat/completions
OLLAMA_MODEL=llama3.1:8b

# Access control (Auditoria): shared pairing token used when Supabase is OFF.
PAIRING_TOKEN=

# STT model id override. VERIFY real NVIDIA NIM ASR model name before production.
NVIDIA_ASR_MODEL=nvidia/nemotron-3.5-asr

# Commercialization settings (Fase C2)
LICENSE_API_URL=https://tbijfdbtauzxbsbkujbs.functions.supabase.co/validate-license
LICENSE_TOKEN=
GITHUB_REPO=Gusitir/LinuxRemotePlayer
# NOTA: enlace de Stripe en MODO TEST — cambiar por el link live antes de vender.
BUY_URL=https://buy.stripe.com/test_5kQ3cv99t9aY8pu1aVe3e00

# Keyboard Layout for UInput Emulator
# Valid values: us | es | latam (default: us)
# Note for es/latam: < and > require KEY_102ND. Brackets/braces via AltGr not covered.
KEYBOARD_LAYOUT=us
